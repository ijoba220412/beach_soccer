{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "A beach soccer team registration",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "teamName": { "type": "string" },
        "coach": { "type": "string" },
        "playerName": { "type": "string" },
        "nickname": { "type": "string" },
        "phone": { "type": "string" },
        "isWhatsapp": { "type": "boolean" },
        "birthDate": { "type": "string" },
        "cep": { "type": "string" },
        "address": { "type": "string" },
        "addressNumber": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "position": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "playerPhoto": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["ownerId", "teamName", "coach", "playerName", "isVerified", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Store all team registrations."
    }
  }
}
