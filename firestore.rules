rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'allan.muniz88@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(ownerId) {
      return request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['ownerId', 'teamName', 'coach', 'playerName', 'isVerified', 'createdAt', 'updatedAt']) 
        && data.ownerId == request.auth.uid
        && data.teamName is string && data.teamName.size() > 0 && data.teamName.size() <= 100
        && data.coach is string && data.coach.size() > 0 && data.coach.size() <= 100
        && data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 100
        && (!('nickname' in data) || (data.nickname is string && data.nickname.size() <= 100))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 25))
        && (!('birthDate' in data) || (data.birthDate is string && data.birthDate.size() <= 20))
        && (!('cep' in data) || (data.cep is string && data.cep.size() <= 20))
        && (!('address' in data) || (data.address is string && data.address.size() <= 150))
        && (!('addressNumber' in data) || (data.addressNumber is string && data.addressNumber.size() <= 20))
        && (!('neighborhood' in data) || (data.neighborhood is string && data.neighborhood.size() <= 100))
        && (!('city' in data) || (data.city is string && data.city.size() <= 100))
        && (!('state' in data) || (data.state is string && data.state.size() <= 50))
        && (!('position' in data) || (data.position is string && data.position.size() <= 50))
        && (!('height' in data) || (data.height is string && data.height.size() <= 10))
        && (!('weight' in data) || (data.weight is string && data.weight.size() <= 10))
        && data.isVerified is bool
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && (!('playerPhoto' in data) || (data.playerPhoto is string && data.playerPhoto.size() <= 800000));
    }
    
    function isValidTeamUpdate(data) {
      return data.keys().hasAll(['ownerId', 'teamName', 'coach', 'playerName', 'isVerified', 'createdAt', 'updatedAt']) 
        && data.ownerId == existing().ownerId
        && data.teamName is string && data.teamName.size() > 0 && data.teamName.size() <= 100
        && data.coach is string && data.coach.size() > 0 && data.coach.size() <= 100
        && data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 100
        && (!('nickname' in data) || (data.nickname is string && data.nickname.size() <= 100))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 25))
        && (!('birthDate' in data) || (data.birthDate is string && data.birthDate.size() <= 20))
        && (!('cep' in data) || (data.cep is string && data.cep.size() <= 20))
        && (!('address' in data) || (data.address is string && data.address.size() <= 150))
        && (!('addressNumber' in data) || (data.addressNumber is string && data.addressNumber.size() <= 20))
        && (!('neighborhood' in data) || (data.neighborhood is string && data.neighborhood.size() <= 100))
        && (!('city' in data) || (data.city is string && data.city.size() <= 100))
        && (!('state' in data) || (data.state is string && data.state.size() <= 50))
        && (!('position' in data) || (data.position is string && data.position.size() <= 50))
        && (!('height' in data) || (data.height is string && data.height.size() <= 10))
        && (!('weight' in data) || (data.weight is string && data.weight.size() <= 10))
        && data.isVerified == existing().isVerified
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time
        && (!('playerPhoto' in data) || (data.playerPhoto is string && data.playerPhoto.size() <= 800000));
    }

    match /teams/{teamId} {
      allow read: if existing().isVerified == true || (request.auth != null && existing().ownerId == request.auth.uid) || isAdmin();
      allow list: if resource.data.isVerified == true || (request.auth != null && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidId(teamId) && isValidTeam(incoming()) && incoming().isVerified == false;
      allow update: if isAuthenticated() && isValidId(teamId) && (
        (isOwner(existing().ownerId) && isValidTeamUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['teamName', 'coach', 'playerName', 'nickname', 'phone', 'birthDate', 'cep', 'address', 'addressNumber', 'neighborhood', 'city', 'state', 'position', 'height', 'weight', 'playerPhoto', 'updatedAt']))
        ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['isVerified', 'updatedAt']) && incoming().isVerified is bool && incoming().updatedAt == request.time)
      );
      allow delete: if isAuthenticated() && isValidId(teamId) && (isOwner(existing().ownerId) || isAdmin());
    }
  }
}
